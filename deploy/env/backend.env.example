# Production .env for backend/  (copy to backend/.env on the server, then run: php artisan key:generate)
APP_NAME=Aman
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://api.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Local MySQL on the same VPS ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aman
DB_USERNAME=aman
DB_PASSWORD=CHANGE_ME_STRONG

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SANCTUM_STATEFUL_DOMAINS=example.com,www.example.com,admin.example.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Telescope is a debug UI — keep it OFF in production
TELESCOPE_ENABLED=false

# Mail: switch from 'log' to real SMTP when ready
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

AMAN_API=https://api.example.com/
