# Production .env for backend/  (copy to backend/.env on the server, then run: php artisan key:generate)
APP_NAME=Aman
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://srv1843351.hstgr.cloud:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Local MySQL on the same VPS ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aman
DB_USERNAME=aman
DB_PASSWORD=CHANGE_ME_STRONG

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SANCTUM_STATEFUL_DOMAINS=srv1843351.hstgr.cloud,srv1843351.hstgr.cloud:8080,srv1843351.hstgr.cloud:8081

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Telescope is a debug UI — keep it OFF in production
TELESCOPE_ENABLED=false

# --- Mail: Gmail SMTP (no domain needed) ---
# Requires a Google App Password: turn on 2-Step Verification, then generate one at
# https://myaccount.google.com/apppasswords . The normal account password will NOT work.
# Gmail forces the From to the authenticated account, so keep MAIL_FROM_ADDRESS = MAIL_USERNAME.
# Free Gmail cap ~500 emails/day. For 'log' (no real send) set MAIL_MAILER=log.
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM_ADDRESS=you@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

AMAN_API=http://srv1843351.hstgr.cloud:8080/
