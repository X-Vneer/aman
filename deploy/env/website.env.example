# Production env for website/  (copy to website/.env.local on the server)
# NEXT_PUBLIC_* are baked at BUILD time -> rebuild if you change them.

NEXT_PUBLIC_API_URL=http://srv1843351.hstgr.cloud:8080
NEXT_PUBLIC_SITE_URL=http://srv1843351.hstgr.cloud

# Encryption key for the aman_session auth cookie (AES-256-GCM).
# Generate with:  openssl rand -base64 32
# Rotating it logs every user out (their cookies stop decrypting).
AUTH_SECRET=CHANGE_ME
