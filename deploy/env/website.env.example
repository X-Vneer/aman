# Production env for website/  (copy to website/.env.local on the server)
# NEXT_PUBLIC_* are baked at BUILD time -> rebuild if you change them.
# AUTH_* are read at runtime by the Node server.

NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_SITE_URL=https://example.com

# next-auth v5. Generate a secret with:  openssl rand -base64 32
AUTH_SECRET=CHANGE_ME
AUTH_URL=https://example.com
# Required because the app runs behind the nginx reverse proxy:
AUTH_TRUST_HOST=true
