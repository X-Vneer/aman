# Copy to .env.local for local dev.
# NEXT_PUBLIC_* are baked at BUILD time — rebuild after changing.

# Base URL of the backend API.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL. Used by share buttons, certificate route, JSON-LD schemas.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Encryption key for the aman_session auth cookie (AES-256-GCM).
# Generate with:  openssl rand -base64 32
# Rotating it logs every user out (their cookies stop decrypting).
AUTH_SECRET=
