APP_NAME=Aman
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local MySQL. Run `php artisan key:generate` after copying this file.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aman
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,localhost:5173,localhost:3000,127.0.0.1

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=localhost

REDIS_CLIENT=phpredis
REDIS_HOST=localhost
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail is 'log' by default in dev (writes to storage/logs) — no real emails sent.
# To send via Gmail SMTP (no domain needed): set MAIL_MAILER=smtp and fill USERNAME/PASSWORD.
# Requires a Google App Password (2FA on -> https://myaccount.google.com/apppasswords);
# the normal account password will NOT work. Gmail forces From = the authenticated account,
# so set MAIL_FROM_ADDRESS = MAIL_USERNAME.
MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# External platform (used by config/app.php)
PLATFORM=
PLATFORM_CERT=

# Base URL the backend uses to build absolute asset/certificate links (config/aman.php)
AMAN_API=http://localhost:8000/
